# Mongo coordinator. Inside the compose network reach it via the autossh
# tunnel sidecar (host=tunnel, port=27017). For a direct connection set the
# real URI with credentials once the coordinator enables auth.
MONGO_URI=mongodb://tunnel:27017/?serverSelectionTimeoutMS=5000
MONGO_DB=dockerhub_data

# Stage II inclusion threshold — repos below this pull_count are not crawled.
PULL_THRESHOLD=72

# Shared secret. Clients must send X-API-Key: <value>. Empty disables auth
# (only acceptable for local dev behind localhost).
API_KEY=change-me-32-bytes-of-entropy

# Comma-separated origins allowed for CORS. Leave empty when frontend is
# served by the same Caddy site as the API (recommended).
CORS_ORIGINS=

# Worker hostnames in display order. Also used as the allow-list for
# POST /api/v1/metrics/{host} uploads — unknown hosts get 403.
WORKER_HOSTS=l01,l03,l04,l06,l07,l08,l09,l12,l13,rtx5080-01,rtx5080-02,rtx3060-01

# Where the worker_logs/<host>/backfill_metrics.log files are written inside
# the backend container (workers POST their tail every minute).
WORKER_LOGS_DIR=/data/worker_logs

# Hard cap on a single metrics upload body (bytes). Above this the endpoint
# returns 413.
METRICS_MAX_BYTES=2097152

# Per-host rate limit (uploads per minute) for POST /api/v1/metrics/{host}.
# The cron pushes once a minute; 12 leaves headroom for retries.
METRICS_RATE_PER_MIN=12

# A worker is "stalled" when its log has not been touched in this many seconds.
STALL_SECONDS=600

# Throughput chart window.
HISTORY_HOURS=24

LOG_LEVEL=INFO

# ---- autossh tunnel sidecar ---------------------------------------------
# Coordinator host reached over SSH (key-only). Drop /etc/ssh-tunnel/id_ed25519
# on the docker host before bringing the stack up.
TUNNEL_SSH_HOST=coordinator.example
TUNNEL_SSH_USER=relay
TUNNEL_SSH_PORT=22
TUNNEL_REMOTE_MONGO=127.0.0.1:27017
